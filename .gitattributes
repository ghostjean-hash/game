# 기본: 텍스트 자동 감지 + LF 고정 (Windows / macOS / Linux / CI 일관성)
* text=auto eol=lf

# Windows 전용 스크립트는 CRLF 유지 (실행 안 되는 경우 방지)
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# macOS .command 스크립트는 LF (bash/zsh 실행)
*.command text eol=lf

# 코드 / 마크업 / 데이터 - 명시적으로 LF
*.js      text eol=lf
*.mjs     text eol=lf
*.cjs     text eol=lf
*.ts      text eol=lf
*.json    text eol=lf
*.jsonl   text eol=lf
*.md      text eol=lf
*.html    text eol=lf
*.css     text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.svg     text eol=lf

# 바이너리 (자동 변환 금지)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.mp3   binary
*.wav   binary
*.ogg   binary
*.mp4   binary
*.pdf   binary
*.zip   binary
